    {
      "parameters": {
        "method": "GET",
        "url": "={{ $vars.CRM_BASE_URL }}/api/n8n/clients/{{ $('Chercher client par email').first().json.client.id }}",
        "sendHeaders": true,
        "headerParameters": {
