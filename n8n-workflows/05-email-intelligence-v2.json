      },
      "id": "get-client-context",
      "name": "Contexte client complet",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        700,
        -100
      ]
    },
    {
      "parameters": {
        "jsCode": "const w=$('Webhook email.received').first().json.body;const cd=$('Chercher client par email').first().json.client;let cc=null;try{cc=$('Contexte client complet').first().json}catch(e){}const p=['Tu es assistant IA du cabinet GargarineV1, courtier en assurances.','Analyse cet email. Reponds en JSON: type, urgence, resume, sentiment, actionRequise, actionSuggeree, draftReply, produitsMentionnes, expediteurNom, expediteurEntreprise','Types: client/prospect/assureur/prescripteur/autre. Urgence: haute/normale/basse','draftReply=null si sortant/autre/pas necessaire','','EMAIL:','De: '+(w.expediteur||''),'Objet: '+(w.sujet||''),'Direction: '+(w.direction||''),'---',w.extrait||'(vide)'];if(cc?.client){const c=cc.client;p.push('','CONTEXTE:','Nom: '+c.raisonSociale,'Statut: '+c.statut)}else if(cd){p.push('','CLIENT:',cd.raisonSociale)}return[{json:{emailId:w.emailId,clientId:w.clientId||cd?.id||null,prompt:p.join('\\n')}}];"
      },
      "id": "build-prompt",
      "name": "Construire prompt IA",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        940,
        0
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "=https://generativelanguage.googleapis.com/v1beta/models/gemini-2.0-flash:generateContent?key={{ $vars.GEMINI_API_KEY }}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ contents: [{ parts: [{ text: $json.prompt }] }], generationConfig: { temperature: 0.2, responseMimeType: 'application/json' } }) }}",
        "options": {
          "timeout": 30000
        }
      },
      "id": "call-gemini",
      "name": "Gemini Flash Analyse",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1180,
        0
      ]
    },
    {
      "parameters": {
        "jsCode": "const g=$input.first().json;const d=$('Construire prompt IA').first().json;const t=g.candidates?.[0]?.content?.parts?.[0]?.text||'{}';let a;try{a=JSON.parse(t)}catch(e){a={type:'autre',urgence:'basse',resume:t.substring(0,200)}}return[{json:{emailId:d.emailId,clientId:d.clientId,...a}}];"
      },
      "id": "parse-result",
      "name": "Parser resultat Gemini",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1400,
        0
      ]
    },
