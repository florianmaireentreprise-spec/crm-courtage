      "id": "if-action",
      "name": "Action requise",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [
        1840,
        0
      ]
    },
    {
      "parameters": {
        "jsCode": "const d=$('Parser resultat Gemini').first().json;const w=$('Webhook email.received').first().json.body;const ms=d.urgence==='haute'?86400000:d.urgence==='basse'?604800000:259200000;return[{json:{titre:'Repondre a '+(d.expediteurNom||'inconnu')+' ('+(w.expediteur||'')+')',description:'Email: '+(w.sujet||'')+'\\nResume: '+(d.resume||''),clientId:d.clientId||null,emailId:d.emailId,type:'RELANCE_PROSPECT',priorite:d.urgence==='haute'?'haute':'normale',dateEcheance:new Date(Date.now()+ms).toISOString(),sourceAuto:'email_reponse_attendue'}}];"
      },
