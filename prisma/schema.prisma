generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  password     String
  prenom       String
  nom          String
  role         String   @default("gerant")
  dateCreation DateTime @default(now())
}

model Client {
  id                   String    @id @default(cuid())
  // Entreprise
  raisonSociale        String
  siret                String?   @unique
  formeJuridique       String?
  secteurActivite      String?
  nbSalaries           Int?
  chiffreAffaires      Float?
  conventionCollective String?
  // Couverture actuelle (qualification)
  mutuelleActuelle     String?
  prevoyanceActuelle   String?
  dateEcheanceMutuelle DateTime?
  dateEcheancePrevoyance DateTime?
  // Dirigeant / contact principal
  civilite             String?
  prenom               String
  nom                  String
  email                String?
  telephone            String?
  adresse              String?
  codePostal           String?
  ville                String?
  dateNaissance        DateTime?
  // Metadonnees
  sourceAcquisition    String?
  prescripteurId       String?
  prescripteur         Prescripteur? @relation(fields: [prescripteurId], references: [id], onDelete: SetNull)
  notes                String?
  statut               String   @default("prospect")
  dateCreation         DateTime @default(now())
  dateMaj              DateTime @updatedAt
  assigneA             String?
  // Enrichissement email
  derniereInteraction  DateTime?
  noteEmails           String?
  // Reseau personnel
  categorieReseau      String?
  // Relations
  contrats             Contrat[]
  deals                Deal[]
  taches               Tache[]
  emails               Email[]
  dirigeant            Dirigeant?
}

model Dirigeant {
  id                  String    @id @default(cuid())
  clientId            String    @unique
  client              Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  // Identite
  civilite            String?
  prenom              String
  nom                 String
  email               String?
  telephone           String?
  dateNaissance       DateTime?
  // Statut
  statutProfessionnel String?   // TNS / assimile_salarie
  // Protection actuelle
  mutuellePerso       String?
  prevoyancePerso     String?
  protectionActuelle  String?   // description libre
  // Retraite & Epargne
  regimeRetraite      String?
  complementaireRetraite String?
  epargneActuelle     String?
  montantEpargne      Float?
  // Besoins
  besoinsPatrimoniaux String?
  objectifsRetraite   String?
  // Suivi
  dateAuditDirigeant  DateTime?
  notes               String?
  dateCreation        DateTime  @default(now())
  dateMaj             DateTime  @updatedAt
}

model Prescripteur {
  id                  String    @id @default(cuid())
  // Identite
  type                String    // expert_comptable / avocat / partenaire / client_prescripteur
  civilite            String?
  prenom              String
  nom                 String
  entreprise          String?
  email               String?
  telephone           String?
  adresse             String?
  ville               String?
  // Performance
  dossiersEnvoyes     Int       @default(0)
  clientsSignes       Int       @default(0)
  commissionsGenerees Float     @default(0)
  // Suivi
  derniereRecommandation DateTime?
  notes               String?
  statut              String    @default("actif")
  dateCreation        DateTime  @default(now())
  dateMaj             DateTime  @updatedAt
  // Relations
  clients             Client[]
  deals               Deal[]
}

model Contrat {
  id                 String       @id @default(cuid())
  clientId           String
  client             Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  // Produit
  typeProduit        String
  compagnieId        String?
  compagnie          Compagnie?   @relation(fields: [compagnieId], references: [id])
  nomProduit         String?
  numeroContrat      String?
  // Financier
  primeAnnuelle      Float
  tauxCommApport     Float?
  tauxCommGestion    Float?
  commissionAnnuelle Float?
  modeVersement      String?
  frequenceVersement String?
  // Dates
  dateEffet          DateTime
  dateEcheance       DateTime?
  dateResiliation    DateTime?
  dateRenouvellement DateTime?
  // Details collectif
  nbBeneficiaires    Int?
  cotisationUnitaire Float?
  // Statut
  statut             String       @default("actif")
  notes              String?
  dateCreation       DateTime     @default(now())
  dateMaj            DateTime     @updatedAt
  // Relations
  commissions        Commission[]
}

model Compagnie {
  id                 String    @id @default(cuid())
  nom                String    @unique
  type               String?
  contactNom         String?
  contactEmail       String?
  contactTelephone   String?
  // Conditions negociees
  conventionSignee   Boolean   @default(false)
  dateConvention     DateTime?
  seuilSurcommission Int?
  tauxSurcommission  Float?
  // Suivi
  nbContratsActifs   Int       @default(0)
  primesCumulees     Float     @default(0)
  notes              String?
  // Relations
  contrats           Contrat[]
}

model Deal {
  id                    String       @id @default(cuid())
  clientId              String
  client                Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  // Pipeline
  titre                 String
  etape                 String       @default("PROSPECT_IDENTIFIE")
  montantEstime         Float?
  probabilite           Int?
  produitsCibles        String?
  // Source prospect
  sourceProspect        String?      // reseau_personnel / prescripteur / recommandation / prospection
  prescripteurId        String?
  prescripteur          Prescripteur? @relation(fields: [prescripteurId], references: [id], onDelete: SetNull)
  // Qualification
  qualificationNotes    String?
  problematiqueDirigeant String?
  // Audit
  checklistAudit        String?      // JSON: {mutuelle: bool, prevoyance: bool, dirigeant: bool, retraite: bool}
  rapportAudit          String?
  syntheseClient        String?
  // Recommandation
  propositionCommerciale String?
  comparatifAssureurs   String?
  simulationCotisations String?
  // Signature
  assureurChoisi        String?
  commissionsAttendues  Float?
  documentsNotes        String?
  // Dates
  dateCreation          DateTime     @default(now())
  dateMaj               DateTime     @updatedAt
  dateClosingPrev       DateTime?
  dateClosingReel       DateTime?
  dateSignature         DateTime?
  dateOnboarding        DateTime?
  // Suivi
  motifPerte            String?
  notes                 String?
  assigneA              String?
}

model Commission {
  id            String    @id @default(cuid())
  contratId     String
  contrat       Contrat   @relation(fields: [contratId], references: [id], onDelete: Cascade)
  // Montant
  montant       Float
  type          String
  periode       String
  dateVersement DateTime?
  statut        String    @default("prevu")
  notes         String?
  dateCreation  DateTime  @default(now())
}

model Tache {
  id              String    @id @default(cuid())
  clientId        String?
  client          Client?   @relation(fields: [clientId], references: [id], onDelete: SetNull)
  emailId         String?
  email           Email?    @relation("EmailTaches", fields: [emailId], references: [id], onDelete: SetNull)
  // Contenu
  titre           String
  description     String?
  type            String
  priorite        String    @default("normale")
  // Dates
  dateEcheance    DateTime
  dateRealisation DateTime?
  statut          String    @default("a_faire")
  assigneA        String?
  recurrence      String?
  // Auto-generation
  autoGenerated   Boolean   @default(false)
  sourceAuto      String?   // echeance_contrat / revision_annuelle / relance_prospect / dev_client / onboarding
  dateCreation    DateTime  @default(now())
}

model Objectif {
  id           String   @id @default(cuid())
  userId       String?
  type         String
  periode      String
  annee        Int
  mois         Int?
  trimestre    Int?
  valeurCible  Float
  dateCreation DateTime @default(now())
  dateMaj      DateTime @updatedAt
}

model GmailConnection {
  id           String   @id @default(cuid())
  userId       String   @unique
  gmailEmail   String
  accessToken  String
  refreshToken String
  tokenExpiry  DateTime
  dateConnecte DateTime @default(now())
  dateMaj      DateTime @updatedAt
}

model Email {
  id              String    @id @default(cuid())
  userId          String
  gmailId         String    @unique
  threadId        String
  sujet           String
  expediteur      String
  destinataires   String
  dateEnvoi       DateTime
  extrait         String?
  // Classification
  direction       String    @default("entrant")
  pertinence      String    @default("normal")
  scoreRelevance  Int       @default(0)
  // Analyse IA
  resume          String?
  actionsItems    String?
  reponseProposee String?
  // Relations
  clientId        String?
  client          Client?   @relation(fields: [clientId], references: [id], onDelete: SetNull)
  taches          Tache[]   @relation("EmailTaches")
  // Statut
  analyseStatut   String    @default("non_analyse")
  lu              Boolean   @default(false)
  dateCreation    DateTime  @default(now())
  dateMaj         DateTime  @updatedAt
}
