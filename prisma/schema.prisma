generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ── Workspace (Phase 1 — Demo/Real separation) ──

model Workspace {
  id        String   @id @default(cuid())
  slug      String   @unique // "demo" | "real"
  nom       String   // "Démonstration" | "Production"
  isDefault Boolean  @default(false) // true = new writes go here
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  clients              Client[]
  dirigeants           Dirigeant[]
  contrats             Contrat[]
  commissions          Commission[]
  deals                Deal[]
  taches               Tache[]
  prescripteurs        Prescripteur[]
  compagnies           Compagnie[]
  documents            Document[]
  opportunites         OpportuniteCommerciale[]
  preconisations       Preconisation[]
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  password     String
  prenom       String
  nom          String
  role         String   @default("gerant")
  dateCreation DateTime @default(now())

  // Attribution relations
  clientsCreated          Client[]                 @relation("ClientCreatedBy")
  clientsUpdated          Client[]                 @relation("ClientUpdatedBy")
  documentsCreated        Document[]               @relation("DocumentCreatedBy")
  documentsUpdated        Document[]               @relation("DocumentUpdatedBy")
  opportunitesCreated     OpportuniteCommerciale[] @relation("OpportuniteCreatedBy")
  opportunitesUpdated     OpportuniteCommerciale[] @relation("OpportuniteUpdatedBy")
  preconisationsCreated   Preconisation[]          @relation("PreconisationCreatedBy")
  preconisationsUpdated   Preconisation[]          @relation("PreconisationUpdatedBy")
  auditLogs               AuditLog[]
}

model Client {
  id                   String    @id @default(cuid())
  workspaceId          String?
  workspace            Workspace? @relation(fields: [workspaceId], references: [id])
  // Entreprise
  raisonSociale        String
  siret                String?   @unique
  formeJuridique       String?
  secteurActivite      String?
  nbSalaries           Int?
  chiffreAffaires      Float?
  conventionCollective String?
  // Couverture actuelle (qualification)
  mutuelleActuelle     String?
  prevoyanceActuelle   String?
  dateEcheanceMutuelle DateTime?
  dateEcheancePrevoyance DateTime?
  // Dirigeant / contact principal
  civilite             String?
  prenom               String
  nom                  String
  email                String?
  telephone            String?
  adresse              String?
  codePostal           String?
  ville                String?
  dateNaissance        DateTime?
  // Metadonnees
  sourceAcquisition    String?
  prescripteurId       String?
  prescripteur         Prescripteur? @relation(fields: [prescripteurId], references: [id], onDelete: SetNull)
  notes                String?
  statut               String   @default("prospect")
  dateCreation         DateTime @default(now())
  dateMaj              DateTime @updatedAt
  assigneA             String?
  // Enrichissement email
  derniereInteraction  DateTime?
  noteEmails           String?
  // Enrichissement entreprise (SIRENE)
  codeNAF              String?
  trancheEffectifs     String?
  // Reseau personnel
  categorieReseau      String?
  typeRelation          String?   // deprecated — use rolesReseau instead
  rolesReseau           String[]  @default([])
  statutReseau          String?
  niveauPotentiel       String?
  potentielAffaires     String?
  potentielEstimeAnnuel Float?
  horizonActivation     String?
  prochaineActionReseau String?
  dateRelanceReseau     DateTime?
  dateDernierContact    DateTime?
  commentaireReseau     String?
  // Veille concurrentielle
  courtierActuel       String?
  assureurActuelSante  String?
  dateDerniereRevision DateTime?
  motifChangement      String?   // prix, service, couverture, conseil
  // Archivage
  archived             Boolean   @default(false)
  archivedAt           DateTime?
  // Intelligence Commerciale
  scoreProspect        Int?       // Score 0-100 (persiste)
  potentielCA          Float?     // € potentiel annuel
  scoreCouverture      Int?       // % couverture 360 (0-100)
  dernierScoring       DateTime?  // Date du dernier calcul
  resumeIA             String?    // Resume IA cumule des interactions
  // Stage 2: Memoire Commerciale Structuree
  temperatureCommerciale  String?    // "chaud" | "tiede" | "froid"
  produitsDiscutes        String?    // JSON: ["SANTE_COLLECTIVE","PER"]
  objectionsConnues       String?    // JSON: ["prix","timing","concurrent"]
  besoinsIdentifies       String?    // JSON: ["SANTE_COLLECTIVE","PER"]
  dernierSignalDate       DateTime?  // Date du dernier signal commercial
  dernierSignalResume     String?    // Court texte max 200 chars
  nbSignaux               Int?       // Nombre total de signaux
  // Attribution
  createdByUserId      String?
  createdByUser        User?     @relation("ClientCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedByUserId      String?
  updatedByUser        User?     @relation("ClientUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)
  // Relations
  contrats             Contrat[]
  deals                Deal[]
  taches               Tache[]
  emails               Email[]
  dirigeant            Dirigeant?
  sequenceInscriptions SequenceInscription[]
  signauxCommerciaux   SignalCommercial[]
  opportunites         OpportuniteCommerciale[]
  documents            Document[]
  preconisations       Preconisation[]
}

model Dirigeant {
  id                  String    @id @default(cuid())
  workspaceId         String?
  workspace           Workspace? @relation(fields: [workspaceId], references: [id])
  clientId            String    @unique
  client              Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  // Identite
  civilite            String?
  prenom              String
  nom                 String
  email               String?
  telephone           String?
  dateNaissance       DateTime?
  // Statut
  statutProfessionnel String?   // TNS / assimile_salarie
  // Protection actuelle
  mutuellePerso       String?
  prevoyancePerso     String?
  protectionActuelle  String?   // description libre
  // Retraite & Epargne
  regimeRetraite      String?
  complementaireRetraite String?
  epargneActuelle     String?
  montantEpargne      Float?
  // Besoins
  besoinsPatrimoniaux String?
  objectifsRetraite   String?
  // Suivi
  dateAuditDirigeant  DateTime?
  notes               String?
  dateCreation        DateTime  @default(now())
  dateMaj             DateTime  @updatedAt
}

model Prescripteur {
  id                  String    @id @default(cuid())
  workspaceId         String?
  workspace           Workspace? @relation(fields: [workspaceId], references: [id])
  // Identite
  type                String    // expert_comptable / avocat / partenaire / client_prescripteur
  civilite            String?
  prenom              String
  nom                 String
  entreprise          String?
  email               String?
  telephone           String?
  adresse             String?
  ville               String?
  // Performance
  dossiersEnvoyes     Int       @default(0)
  clientsSignes       Int       @default(0)
  commissionsGenerees Float     @default(0)
  // Suivi
  derniereRecommandation DateTime?
  notes               String?
  statut              String    @default("actif")
  // Archivage
  archived            Boolean   @default(false)
  archivedAt          DateTime?
  dateCreation        DateTime  @default(now())
  dateMaj             DateTime  @updatedAt
  // Relations
  clients             Client[]
  deals               Deal[]
}

model Contrat {
  id                 String       @id @default(cuid())
  workspaceId        String?
  workspace          Workspace?   @relation(fields: [workspaceId], references: [id])
  clientId           String
  client             Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  // Produit
  typeProduit        String
  compagnieId        String?
  compagnie          Compagnie?   @relation(fields: [compagnieId], references: [id])
  nomProduit         String?
  numeroContrat      String?
  // Financier
  primeAnnuelle      Float
  tauxCommApport     Float?
  tauxCommGestion    Float?
  commissionAnnuelle Float?
  modeVersement      String?
  frequenceVersement String?
  // Dates
  dateEffet          DateTime
  dateEcheance       DateTime?
  dateResiliation    DateTime?
  dateRenouvellement DateTime?
  // Details collectif
  nbBeneficiaires    Int?
  cotisationUnitaire Float?
  // Statut
  statut             String       @default("actif")
  notes              String?
  dateCreation       DateTime     @default(now())
  dateMaj            DateTime     @updatedAt
  // Relations
  commissions        Commission[]
}

model Compagnie {
  id                 String    @id @default(cuid())
  workspaceId        String?
  workspace          Workspace? @relation(fields: [workspaceId], references: [id])
  nom                String    @unique
  type               String?
  contactNom         String?
  contactEmail       String?
  contactTelephone   String?
  // Conditions negociees
  conventionSignee   Boolean   @default(false)
  dateConvention     DateTime?
  seuilSurcommission Int?
  tauxSurcommission  Float?
  // Suivi
  nbContratsActifs   Int       @default(0)
  primesCumulees     Float     @default(0)
  notes              String?
  // Relations
  contrats           Contrat[]
  produits           CompagnieProduit[]
}

model CompagnieProduit {
  id                 String    @id @default(cuid())
  compagnieId        String
  compagnie          Compagnie @relation(fields: [compagnieId], references: [id], onDelete: Cascade)
  typeProduit        String
  tauxCommission     Float     // Stored as decimal (0.07 = 7%)
  seuilSurcommission Int?
  tauxSurcommission  Float?    // Stored as decimal
  upfront            Float?    // Ticket at signature in EUR

  @@unique([compagnieId, typeProduit])
}

model Deal {
  id                    String       @id @default(cuid())
  workspaceId           String?
  workspace             Workspace?   @relation(fields: [workspaceId], references: [id])
  clientId              String
  client                Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  // Pipeline
  titre                 String
  etape                 String       @default("PROSPECT_IDENTIFIE")
  montantEstime         Float?
  probabilite           Int?
  produitsCibles        String?
  // Source prospect
  sourceProspect        String?      // reseau_personnel / prescripteur / recommandation / prospection
  prescripteurId        String?
  prescripteur          Prescripteur? @relation(fields: [prescripteurId], references: [id], onDelete: SetNull)
  // Qualification
  qualificationNotes    String?
  problematiqueDirigeant String?
  // Audit
  checklistAudit        String?      // JSON: {mutuelle: bool, prevoyance: bool, dirigeant: bool, retraite: bool}
  rapportAudit          String?
  syntheseClient        String?
  // Recommandation
  propositionCommerciale String?
  comparatifAssureurs   String?
  simulationCotisations String?
  // Signature
  assureurChoisi        String?
  commissionsAttendues  Float?
  documentsNotes        String?
  // Dates
  dateCreation          DateTime     @default(now())
  dateMaj               DateTime     @updatedAt
  dateClosingPrev       DateTime?
  dateClosingReel       DateTime?
  dateSignature         DateTime?
  dateOnboarding        DateTime?
  // Suivi
  motifPerte            String?
  notes                 String?
  assigneA              String?
  // Relations
  preconisations        Preconisation[]
}

model Commission {
  id            String    @id @default(cuid())
  workspaceId   String?
  workspace     Workspace? @relation(fields: [workspaceId], references: [id])
  contratId     String
  contrat       Contrat   @relation(fields: [contratId], references: [id], onDelete: Cascade)
  // Montant
  montant       Float
  type          String
  periode       String
  dateVersement DateTime?
  statut        String    @default("prevu")
  notes         String?
  dateCreation  DateTime  @default(now())
}

model Tache {
  id              String    @id @default(cuid())
  workspaceId     String?
  workspace       Workspace? @relation(fields: [workspaceId], references: [id])
  clientId        String?
  client          Client?   @relation(fields: [clientId], references: [id], onDelete: SetNull)
  emailId         String?
  email           Email?    @relation("EmailTaches", fields: [emailId], references: [id], onDelete: SetNull)
  // Contenu
  titre           String
  description     String?
  type            String
  priorite        String    @default("normale")
  // Dates
  dateEcheance    DateTime
  dateRealisation DateTime?
  statut          String    @default("a_faire")
  assigneA        String?
  recurrence      String?
  // Auto-generation
  autoGenerated   Boolean   @default(false)
  sourceAuto      String?   // echeance_contrat / revision_annuelle / relance_prospect / dev_client / onboarding / fidelisation_client / suivi_prescripteur / couverture_incomplete / sequence
  // Auto-close
  autoFermee       Boolean   @default(false)
  raisonFermeture  String?   // "Email sortant détecté — Re: Devis santé"
  dateCreation    DateTime  @default(now())
}

model Objectif {
  id           String   @id @default(cuid())
  userId       String?
  type         String
  periode      String
  annee        Int
  mois         Int?
  trimestre    Int?
  valeurCible  Float
  dateCreation DateTime @default(now())
  dateMaj      DateTime @updatedAt
}

model ReseauObjectif {
  id                  String   @id @default(cuid())
  categorie           String   @unique // correspond a CATEGORIES_RESEAU id
  contactsObjectif    Int      @default(0)
  tauxConversionObj   Float    @default(0) // % objectif
  potentielUnitaire   Float    @default(0) // CA moyen par client converti
  notes               String?
  dateCreation        DateTime @default(now())
  dateMaj             DateTime @updatedAt
}

model GmailConnection {
  id           String    @id @default(cuid())
  userId       String    @unique
  gmailEmail   String
  accessToken  String
  refreshToken String
  tokenExpiry  DateTime
  historyId    String?
  pushExpiry   DateTime?
  dateConnecte DateTime  @default(now())
  dateMaj      DateTime  @updatedAt
}

model Email {
  id              String    @id @default(cuid())
  userId          String
  gmailId         String    @unique
  threadId        String
  sujet           String
  expediteur      String
  destinataires   String
  dateEnvoi       DateTime
  extrait         String?
  // Classification
  direction       String    @default("entrant")
  pertinence      String    @default("normal")
  scoreRelevance  Int       @default(0)
  // Analyse IA
  resume          String?
  actionsItems    String?
  reponseProposee String?
  typeEmail       String?   // client, prospect, assureur, prescripteur, autre
  urgence         String?   // haute, normale, basse
  sentiment       String?   // positif, neutre, negatif
  actionRequise   Boolean   @default(false)
  actionTraitee   Boolean   @default(false)
  analyseIA       String?   // JSON complet de l'analyse
  dealUpdateSuggestion String? // JSON: { etape_suggeree, raison }
  produitsMentionnes   String? // JSON array de produits detectes
  // Brouillon Gmail
  gmailDraftId    String?   // ID du brouillon Gmail
  draftStatut     String?   // "brouillon" | "envoye" | null
  notes           String?   // Notes/commentaires manuels de l'utilisateur
  // Relations
  clientId        String?
  client          Client?   @relation(fields: [clientId], references: [id], onDelete: SetNull)
  taches          Tache[]   @relation("EmailTaches")
  feedbacks       FeedbackIA[]
  opportunites    OpportuniteCommerciale[]
  // Statut
  analyseStatut   String    @default("non_analyse")
  lu              Boolean   @default(false)
  dateCreation    DateTime  @default(now())
  dateMaj         DateTime  @updatedAt
}

// ── Sequences de prospection ──

model Sequence {
  id              String    @id @default(cuid())
  nom             String
  description     String?
  etapes          String    // JSON: Array<{ jour: number, action: string, titre: string, type?: string, prompt?: string, motif?: string }>
  active          Boolean   @default(true)
  dateCreation    DateTime  @default(now())
  dateMaj         DateTime  @updatedAt
  inscriptions    SequenceInscription[]
}

model SequenceInscription {
  id                   String    @id @default(cuid())
  sequenceId           String
  sequence             Sequence  @relation(fields: [sequenceId], references: [id], onDelete: Cascade)
  clientId             String
  client               Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  etapeActuelle        Int       @default(0)
  statut               String    @default("en_cours") // en_cours, terminee, annulee
  dateInscription      DateTime  @default(now())
  dateProchaineAction  DateTime?
  dateMaj              DateTime  @updatedAt
}

// ── Logs n8n ──

model N8nLog {
  id           String   @id @default(cuid())
  direction    String   // 'crm_to_n8n' | 'n8n_to_crm'
  eventType    String   // ex: 'email.received', 'POST /api/n8n/taches'
  payload      Json?    // Payload résumé (pas de données sensibles)
  statut       String   // 'success' | 'error'
  erreur       String?  // Message d'erreur si statut = error
  dureeMs      Int?     // Durée de l'appel en millisecondes
  dateCreation DateTime @default(now())
}

// ── Rapports hebdomadaires ──

model RapportHebdo {
  id              String    @id @default(cuid())
  semaine         String    // Format: "2026-W10"
  contenu         String    // JSON du rapport complet
  resumeIA        String?   // Resume genere par IA
  actionsIA       String?   // JSON: top 3 actions prioritaires
  dateGeneration  DateTime  @default(now())
}



// -- Stage 2: Memoire Commerciale Structuree --

model SignalCommercial {
  id           String   @id @default(cuid())
  clientId     String
  client       Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  emailId      String?
  typeSignal   String   // produit_mentionne | sentiment_positif | sentiment_negatif | objection | besoin | deal_update | urgence_haute
  valeur       String   // Code produit, type objection, ou texte libre
  details      String?  // Contexte libre (max 200 chars)
  source       String   // email_analysis | manual
  dateSignal   DateTime @default(now())
  dateCreation DateTime @default(now())

  @@index([clientId, dateSignal])
  @@index([clientId, typeSignal])
}

// ── Intelligence Commerciale : Feedback IA ──

model FeedbackIA {
  id            String   @id @default(cuid())
  emailId       String
  email         Email    @relation(fields: [emailId], references: [id], onDelete: Cascade)
  userId        String
  type          String   // action_executed | action_ignored | type_corrected | urgence_corrected | reply_sent | reply_edited | client_linked
  champ         String?  // champ corrige (ex: "typeEmail", "urgence")
  valeurIA      String?  // valeur proposee par IA
  valeurUser    String?  // valeur corrigee par user
  metadata      String?  // JSON contextuel
  dateCreation  DateTime @default(now())
}
// ── Parametres du cabinet (singleton) ──

model Settings {
  id                String   @id @default("default")
  // Informations cabinet
  raisonSociale     String   @default("GargarineV1")
  formeJuridique    String   @default("SARL")
  gerants           String   @default("Florian MAIRE & Jeremy DELCOURT")
  zone              String   @default("Grand Est, France")
  cible             String   @default("TPE / PME / TNS")
  // Taux de commission par defaut (JSON)
  tauxCommission    String   @default("{}")
  // Timestamps
  dateMaj           DateTime @updatedAt
}

// -- Stage 3: Opportunity Engine --

model OpportuniteCommerciale {
  id                String   @id @default(cuid())
  workspaceId       String?
  workspace         Workspace? @relation(fields: [workspaceId], references: [id])
  clientId          String
  client            Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  sourceType        String   // "signal" | "email_analysis" | "cross_sell" | "manual"
  sourceEmailId     String?
  sourceEmail       Email?   @relation(fields: [sourceEmailId], references: [id], onDelete: SetNull)
  typeProduit       String?  // SANTE_COLLECTIVE, PER, etc.
  titre             String
  description       String?
  statut            String   @default("detectee") // detectee | qualifiee | en_cours | gagnee | perdue | rejetee
  confiance         String   @default("moyenne")  // haute | moyenne | basse
  temperature       String?  // chaud | tiede | froid
  origineSignal     String?  // type of signal that triggered detection
  dedupeKey         String   // clientId:typeProduit:sourceType
  detecteeLe        DateTime @default(now())
  derniereActivite  DateTime @default(now())
  convertieEnDealId String?  // link to Deal if converted
  motifRejet        String?
  closedAt          DateTime?
  closeReason       String?
  metadata          Json?
  // Attribution
  createdByUserId   String?
  createdByUser     User?    @relation("OpportuniteCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedByUserId   String?
  updatedByUser     User?    @relation("OpportuniteUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([clientId])
  @@index([statut])
  @@index([dedupeKey])
}

// -- GED V1: Document Management --

model Document {
  id              String    @id @default(cuid())
  workspaceId     String?
  workspace       Workspace? @relation(fields: [workspaceId], references: [id])
  clientId        String
  client          Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  contratId       String?
  opportuniteId   String?
  dealId          String?
  sourceEmailId   String?
  // Fichier
  nomFichier      String    // Nom original du fichier uploade
  nomAffiche      String    // Nom affiche dans le CRM (modifiable)
  categorie       String    // administratif | conseil | contractuel | echange
  typeDocument    String    // piece_identite | contrat | audit | etc.
  source          String    @default("upload_manuel") // upload_manuel | email_piece_jointe | genere_crm | importe
  mimeType        String
  tailleOctets    Int
  // Vercel Blob
  storageKey      String    // Blob pathname
  storageUrl      String    // Blob URL (private)
  // Dates
  dateDocument    DateTime? // Date du document (ex: date du contrat)
  dateExpiration  DateTime? // Date d'expiration le cas echeant
  // Gestion
  archive         Boolean   @default(false)
  notes           String?
  tags            String?   // JSON array: ["urgent","original"]
  // Attribution
  createdByUserId String?
  createdByUser   User?     @relation("DocumentCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedByUserId String?
  updatedByUser   User?     @relation("DocumentUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)
  // Timestamps
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([clientId])
  @@index([clientId, archive])
  @@index([categorie])
}

// -- Preconisations (Structured Recommendations) --

model Preconisation {
  id              String    @id @default(cuid())
  workspaceId     String?
  workspace       Workspace? @relation(fields: [workspaceId], references: [id])
  clientId        String
  client          Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  dealId          String?
  deal            Deal?     @relation(fields: [dealId], references: [id], onDelete: SetNull)
  // Contenu
  theme           String    // mutuelle_collective, prevoyance, retraite, epargne, remuneration, patrimonial, autre
  titre           String
  justification   String?
  priorite        String    @default("moyenne") // basse, moyenne, haute
  statut          String    @default("a_preparer") // a_preparer, presentee, en_discussion, validee, refusee, reportee
  prochainePas    String?
  notes           String?
  // Attribution
  createdByUserId String?
  createdByUser   User?     @relation("PreconisationCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedByUserId String?
  updatedByUser   User?     @relation("PreconisationUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)
  // Timestamps
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([clientId])
  @@index([statut])
}

// -- Audit Trail --

model AuditLog {
  id            String   @id @default(cuid())
  entityType    String   // "Client" | "Document" | "OpportuniteCommerciale"
  entityId      String
  action        String   // "create" | "update" | "archive" | "unarchive" | "delete" | "delete_blocked"
  actorUserId   String?
  actorUser     User?    @relation(fields: [actorUserId], references: [id], onDelete: SetNull)
  metadata      Json?    // changedFields, blockedDependencies, etc.
  createdAt     DateTime @default(now())

  @@index([entityType, entityId])
  @@index([actorUserId])
  @@index([createdAt])
}
