# ═══════════════════════════════════════════════════════
# DEMO ENVIRONMENT — CRM Courtage
# ═══════════════════════════════════════════════════════
#
# Copy to .env.local for local demo, or set in Vercel dashboard
# for the deployed demo project.
#
# Architecture: Same codebase, separate Vercel project + Neon branch.
# All external integrations are DISABLED via empty env vars.
#
# To seed demo data:
#   DIRECT_URL=<demo-neon-direct-url> npx tsx scripts/seed-demo.ts
#
# Login: demo@gargarine.fr / demo123
# ═══════════════════════════════════════════════════════

# ── Database — Neon DEMO branch (separate from production) ──
DATABASE_URL=postgresql://user:pass@demo-branch-pooler.neon.tech/neondb?sslmode=require
DIRECT_URL=postgresql://user:pass@demo-branch-direct.neon.tech/neondb?sslmode=require

# ── Auth ──
AUTH_SECRET=<generate-a-random-secret-for-demo>
NEXTAUTH_URL=https://demo-crm-courtage.vercel.app

# ── Gmail — DISABLED ──
# Empty = OAuth flow gracefully skipped (try/catch in /emails page)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GMAIL_PUBSUB_TOPIC=

# ── n8n — DISABLED ──
# Empty URL = outbound events silently dropped (emitN8nEvent returns at line 25)
# Empty secret = inbound requests rejected 401 (validateN8nRequest returns false)
N8N_WEBHOOK_URL=
N8N_WEBHOOK_SECRET=
N8N_API_KEY=
N8N_GENERATE_REPLY_URL=

# ── Inbox Zero — DISABLED ──
INBOX_ZERO_WEBHOOK_SECRET=

# ── Vercel Blob — DISABLED ──
# Documents tab visible (metadata from DB), upload/download show graceful error
BLOB_READ_WRITE_TOKEN=

# ── Demo mode indicator ──
# Shows amber banner "Mode demonstration — Donnees fictives"
# Prefixes page title with "[DEMO]"
NEXT_PUBLIC_DEMO_MODE=true
